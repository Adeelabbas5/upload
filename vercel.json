{
  "version": 2,
  "env": {
    "APP_STORAGE": "/tmp",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "CACHE_DIR": "/tmp/storage/framework/cache"
  },
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.9.0"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "api/index.php" }
  ]
}