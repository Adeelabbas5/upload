{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.9.0"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|uploads)/(.*)",
      "dest": "public/$1/$2"
    },
    {
      "src": "/robots\\.txt$",
      "dest": "public/robots.txt"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "public/index.php"
    }
  ]
}